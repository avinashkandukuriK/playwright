{
  "name": "playwright-automation-enterprise",
  "version": "1.0.0",
  "description": "Generic enterprise-ready Playwright TypeScript framework with command-line and portal execution modes.",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avinashkandukuriK/playwright.git"
  },
  "scripts": {
    "test": "playwright test --config playwright.config.ts",
    "test:cmd": "playwright test --config playwright.config.ts",
    "test:runner": "node runner/run-tests.cjs",
    "test:portal": "node runner/run-tests.cjs --portal",
    "test:reference": "playwright test --config playwright.config.ts tests/e2e/reference",
    "test:smoke": "playwright test --config playwright.config.ts --grep @smoke",
    "test:regression": "playwright test --config playwright.config.ts --grep @regression",
    "test:web": "playwright test --config playwright.config.ts --grep @web",
    "test:api": "playwright test --config playwright.config.ts --grep @api",
    "test:headed": "playwright test --config playwright.config.ts --headed",
    "report": "playwright show-report artifacts/playwright-report",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "typescript",
    "sdet",
    "test-automation"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/avinashkandukuriK/playwright/issues"
  },
  "homepage": "https://github.com/avinashkandukuriK/playwright#readme",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.19.43",
    "typescript": "^5.9.3"
  }
}
