{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": ["playwright.config.ts", "src/**/*.ts", "tests/e2e/**/*.ts"],
  "exclude": ["node_modules", "artifacts", "allure-report", "allure-results", "legacy"]
}
